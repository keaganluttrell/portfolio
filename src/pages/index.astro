---
import BaseLayout from '../layouts/BaseLayout.astro';
import AnimatedSection from '../components/AnimatedSection';
import AnimatedReveal from '../components/AnimatedReveal';
import AnimatedCard from '../components/AnimatedCard';
import TextReveal from '../components/TextReveal';
import HeroIntro from '../components/HeroIntro';
import CursorSpotlight from '../components/CursorSpotlight';
import MagneticButton from '../components/MagneticButton';
import Marquee from '../components/Marquee.astro';

import StatusPill from '../components/StatusPill.astro';

const skills = [
  'AI Systems',
  'Agent Infrastructure',
  'Memory Systems',
  'Multi-Agent Orchestration',
  'MCP',
  'SRE',
  'React',
  'TypeScript',
  'Python',
  'Cloudflare',
  'Astro',
  'Systems Thinking',
];
---
<BaseLayout
  title="Keagan Luttrell"
  description="AI Systems Engineer. Building agent-native infrastructure. Army EOD → SRE → Founder → AI."
>
  <section class="hero">
    <CursorSpotlight client:load />
    <HeroIntro client:load />
    <StatusPill status="Currently: Director-level AI roles" />
    <TextReveal text="Keagan Luttrell" as="h1" syncWithIntro client:load />
    <p class="tagline">AI Systems Engineer · Nashville, TN</p>

    <p>
      I build the infrastructure that makes AI systems actually work. Not demos —
      production agent systems with memory, orchestration, tooling, and deployment pipelines.
      The unglamorous plumbing that turns language models into useful software.
    </p>

    <p>
      My path here was unusual: infantry scout, then bomb disposal with Army EOD, then SRE at
      HCA Healthcare keeping critical systems alive at scale, then founding and selling Golden
      Bear, and now building AI agent infrastructure at <strong>Bolt Farm Treehouse</strong>
      (BoltOS). Each step taught me something the previous one couldn't.
    </p>

    <p>
      I think in systems. I see the shape of things before they exist. And I have the
      follow-through to build them — not because of work ethic, but because I'm compelled.
      If there's friction, I remove it. If there's no tool for the job, I make one.
    </p>
  </section>

  <Marquee items={skills} />

  <AnimatedReveal client:visible>
    <div class="section-label" data-num="01">Now</div>
  </AnimatedReveal>
  <div class="card-grid">
    <AnimatedCard client:visible>
      <h3>Building agent-native infrastructure</h3>
      <p>Memory systems, multi-agent orchestration, self-improving pipelines, MCP integrations. The layer between raw models and real utility.</p>
      <div class="meta">Bolt Farm Treehouse · 2025 – present</div>
    </AnimatedCard>
    <AnimatedCard delay={0.12} client:visible>
      <h3>Seeking Director-level AI leadership</h3>
      <p>Looking for the right team to build with — not just a job. Open to founding something new with the right person.</p>
      <div class="meta">Open · Nashville or remote</div>
    </AnimatedCard>
  </div>

  <AnimatedSection client:visible>
    <div class="section-label" data-num="02">Writing</div>
    <p>
      I publish notes on AI infrastructure, systems thinking, and the intersection of
      contemplative practice and engineering. <a href="/writing">Read the notes</a>.
    </p>
  </AnimatedSection>

  <AnimatedSection client:visible>
    <div class="section-label" data-num="03">Connect</div>
    <p class="connect-links">
      <MagneticButton href="https://github.com/keaganluttrell" target="_blank" rel="noopener" client:visible>github</MagneticButton>
      <span aria-hidden="true"> · </span>
      <MagneticButton href="https://linkedin.com/in/keaganluttrell" target="_blank" rel="noopener" client:visible>linkedin</MagneticButton>
      <span aria-hidden="true"> · </span>
      <MagneticButton href="https://x.com/xkeaganluttrell" target="_blank" rel="noopener" client:visible>x</MagneticButton>
      <span aria-hidden="true"> · </span>
      <MagneticButton href="mailto:keaganluttrell7@gmail.com" client:visible>email</MagneticButton>
    </p>
  </AnimatedSection>
</BaseLayout>
