---
import AnimatedNav from '../components/AnimatedNav';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = "Keagan Luttrell",
  description = "AI Systems Engineer. Building agent-native infrastructure.",
  ogImage = "/og-image.png",
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0a1628" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Keagan Luttrell" />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <title>{title}</title>

    <!-- JSON-LD Person schema -->
    <script type="application/ld+json">
      {JSON.stringify({
        "@context": "https://schema.org",
        "@type": "Person",
        name: "Keagan Luttrell",
        jobTitle: "AI Systems Engineer",
        worksFor: {
          "@type": "Organization",
          name: "Bolt Farm Treehouse",
        },
        url: "https://keagan.ai",
        sameAs: [
          "https://github.com/keaganluttrell",
          "https://x.com/xkeaganluttrell",
        ],
        description: "AI Systems Engineer building agent-native infrastructure.",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Nashville",
          addressRegion: "TN",
          addressCountry: "US",
        },
      })}
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>

    <header class="site-header">
      <div class="inner">
        <AnimatedNav activePath={Astro.url.pathname} client:load />
      </div>
    </header>

    <main id="main">
      <div class="container">
        <slot />
      </div>
    </main>

    <footer class="site-footer">
      <div class="inner">
        <p>Keagan Luttrell</p>
        <p>Nashville, TN</p>
      </div>
    </footer>
  </body>
</html>
