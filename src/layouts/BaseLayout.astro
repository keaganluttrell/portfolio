---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Keagan Luttrell",
  description = "AI Systems Engineer. Building the infrastructure of intelligence.",
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <style>
      /* ── Reset & Base ── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #0a0a0b;
        --surface: #111113;
        --border: #1e1e22;
        --text: #e4e4e7;
        --text-dim: #71717a;
        --text-muted: #52525b;
        --accent: #60a5fa;
        --accent-dim: rgba(96, 165, 250, 0.1);
        --font: 'SF Mono', 'Fira Code', 'Cascadia Code', monospace;
        --font-body: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
        --max-width: 720px;
      }

      html { font-size: 16px; -webkit-font-smoothing: antialiased; }

      body {
        font-family: var(--font-body);
        background: var(--bg);
        color: var(--text);
        line-height: 1.7;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      /* ── Layout ── */
      .container {
        max-width: var(--max-width);
        width: 100%;
        margin: 0 auto;
        padding: 0 1.5rem;
        flex: 1;
      }

      /* ── Header / Nav ── */
      header {
        border-bottom: 1px solid var(--border);
        padding: 1.25rem 0;
      }

      header .inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo {
        font-family: var(--font);
        font-size: 0.85rem;
        color: var(--text);
        text-decoration: none;
        letter-spacing: 0.02em;
      }

      .logo:hover { color: var(--accent); }

      nav {
        display: flex;
        gap: 1.5rem;
        align-items: center;
      }

      nav a {
        font-family: var(--font);
        font-size: 0.8rem;
        color: var(--text-dim);
        text-decoration: none;
        transition: color 0.15s;
      }

      nav a:hover, nav a[aria-current="page"] {
        color: var(--text);
      }

      /* ── Main content ── */
      main {
        padding: 3rem 0 5rem;
      }

      /* ── Typography ── */
      h1 {
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
        line-height: 1.3;
      }

      h2 {
        font-size: 1.1rem;
        font-weight: 600;
        letter-spacing: -0.01em;
        margin: 2.5rem 0 1rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
      }

      h3 {
        font-size: 0.95rem;
        font-weight: 600;
        margin: 1.5rem 0 0.5rem;
        color: var(--text);
      }

      p {
        margin-bottom: 1.25rem;
        color: var(--text-dim);
      }

      a {
        color: var(--accent);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }

      strong { color: var(--text); font-weight: 600; }

      /* ── Utility ── */
      .tagline {
        font-family: var(--font);
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-bottom: 2.5rem;
      }

      .section-label {
        font-family: var(--font);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        margin-bottom: 1rem;
      }

      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 1.5rem;
        margin-bottom: 1rem;
        transition: border-color 0.15s;
      }

      .card:hover {
        border-color: var(--text-muted);
      }

      .card h3 {
        margin: 0 0 0.25rem;
      }

      .card p {
        margin: 0;
        font-size: 0.9rem;
      }

      .card .meta {
        font-family: var(--font);
        font-size: 0.75rem;
        color: var(--text-muted);
        margin-top: 0.75rem;
      }

      /* ── Footer ── */
      footer {
        border-top: 1px solid var(--border);
        padding: 1.5rem 0;
        margin-top: auto;
      }

      footer .inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      footer p {
        font-family: var(--font);
        font-size: 0.75rem;
        color: var(--text-muted);
        margin: 0;
      }

      /* ── Lists ── */
      ul, ol {
        margin: 0 0 1.25rem 1.25rem;
        color: var(--text-dim);
      }

      li {
        margin-bottom: 0.35rem;
      }

      /* ── Responsive ── */
      @media (max-width: 640px) {
        header .inner { flex-direction: column; gap: 0.75rem; }
        nav { gap: 1rem; }
        h1 { font-size: 1.5rem; }
        main { padding: 2rem 0 3rem; }
        footer .inner { flex-direction: column; gap: 0.5rem; text-align: center; }
      }
    </style>
  </head>
  <body>
    <header>
      <div class="inner">
        <a href="/" class="logo">kl</a>
        <nav>
          <a href="/" aria-current={Astro.url.pathname === "/" ? "page" : undefined}>home</a>
          <a href="/about" aria-current={Astro.url.pathname === "/about" ? "page" : undefined}>about</a>
          <a href="/projects" aria-current={Astro.url.pathname === "/projects" ? "page" : undefined}>projects</a>
          <a href="mailto:keaganluttrell7@gmail.com">contact</a>
        </nav>
      </div>
    </header>

    <main>
      <div class="container">
        <slot />
      </div>
    </main>

    <footer>
      <div class="inner">
        <p>Keagan Luttrell</p>
        <p>Nashville, TN</p>
      </div>
    </footer>
  </body>
</html>
